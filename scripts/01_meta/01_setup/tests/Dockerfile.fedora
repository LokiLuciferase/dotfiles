FROM fedora:latest

ARG DOTFILES_MACHINE_TYPE=headless
ARG DOTFILES_INSTALL_HEAVY_DEV=false
ARG DOTFILES_TESTING=true

RUN dnf install -y ca-certificates curl git sudo which \
    && dnf clean all

RUN useradd -m testuser -s /bin/bash \
    && echo "testuser ALL=(ALL) NOPASSWD: ALL" >> /etc/sudoers

COPY --chown=testuser:testuser . /home/testuser/.dotfiles

USER testuser
WORKDIR /home/testuser
ENV PATH=/home/testuser/.local/bin:$PATH

RUN DOTFILES_MACHINE_TYPE=${DOTFILES_MACHINE_TYPE} \
    DOTFILES_INSTALL_HEAVY_DEV=${DOTFILES_INSTALL_HEAVY_DEV} \
    DOTFILES_TESTING=${DOTFILES_TESTING} \
    DOTFILES_SYSTEM_PACKAGE_MANAGER=dnf \
    /home/testuser/.dotfiles/scripts/01_meta/01_setup/bootstrap.sh
