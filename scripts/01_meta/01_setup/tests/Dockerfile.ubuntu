FROM ubuntu:24.04

ENV LANG=C.UTF-8 LC_ALL=C.UTF-8
ARG DEBIAN_FRONTEND=noninteractive
ARG TZ=Etc/UTC

ARG DOTFILES_MACHINE_TYPE=headless
ARG DOTFILES_INSTALL_WORK=false
ARG DOTFILES_INSTALL_WAYLAND=false
ARG DOTFILES_INSTALL_HEAVY_DEV=false
ARG DOTFILES_TESTING=true

RUN echo 'debconf debconf/frontend select Noninteractive' | debconf-set-selections
RUN --mount=type=cache,target=/var/cache/apt \
    apt-get update --fix-missing \
    && apt-get install --yes ca-certificates curl git sudo adduser \
    && apt-get clean

RUN useradd -m testuser -s /bin/bash \
    && adduser testuser sudo \
    && echo "testuser ALL=(ALL) NOPASSWD: ALL" >> /etc/sudoers

COPY --chown=testuser:testuser . /home/testuser/.dotfiles
RUN chmod +x /home/testuser/.dotfiles/scripts/01_meta/01_setup/tests/start-vnc.sh \
    && if [ "${DOTFILES_MACHINE_TYPE}" = "gui" ]; then \
        apt-get update --fix-missing \
        && apt-get install --yes \
            dbus-x11 \
            tigervnc-common \
            tigervnc-standalone-server \
            x11-xserver-utils \
            xterm \
        && apt-get clean; \
    fi

USER testuser
WORKDIR /home/testuser
ENV PATH=/home/testuser/.local/bin:$PATH

RUN --mount=type=cache,target=/var/cache/apt \
    DOTFILES_MACHINE_TYPE=${DOTFILES_MACHINE_TYPE} \
    DOTFILES_INSTALL_WORK=${DOTFILES_INSTALL_WORK} \
    DOTFILES_INSTALL_WAYLAND=${DOTFILES_INSTALL_WAYLAND} \
    DOTFILES_INSTALL_HEAVY_DEV=${DOTFILES_INSTALL_HEAVY_DEV} \
    DOTFILES_TESTING=${DOTFILES_TESTING} \
    /home/testuser/.dotfiles/scripts/01_meta/01_setup/bootstrap.sh

RUN bash -lc 'source ~/.local/share/nvm/nvm.sh && node --version && npm --version && ~/.local/bin/uv --version'

EXPOSE 5901
